# =============================================================================
# Velora — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
*.pem
*.key
*.cert

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# Poetry
poetry.lock    # keep in version control — remove this line if you prefer

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover
*.py,cover

# Ruff
.ruff_cache/

# ---------------------------------------------------------------------------
# Node / Next.js
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.next/
out/
.turbo/
next-env.d.ts
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.iml
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.docker/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
