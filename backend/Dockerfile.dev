# =============================================================================
# Velora Backend — Development Dockerfile
# =============================================================================
# Hot-reloads on file changes via uvicorn --reload.
# Do NOT use this in production.

FROM python:3.12-slim

WORKDIR /app

# Install system dependencies (for asyncpg, bcrypt)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Poetry
ENV POETRY_VERSION=1.8.4
ENV POETRY_HOME=/opt/poetry
ENV POETRY_VENV_IN_PROJECT=false
ENV POETRY_NO_INTERACTION=1
ENV PATH="/opt/poetry/bin:$PATH"

RUN pip install --no-cache-dir "poetry==${POETRY_VERSION}"

# Install dependencies (including dev dependencies)
COPY pyproject.toml poetry.lock* ./
RUN poetry install --no-root

# The app code is mounted as a volume in docker-compose.yml
# so we don't COPY here — changes are reflected immediately.

EXPOSE 8000

CMD ["poetry", "run", "uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
