# =============================================================================
# Velora Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENVIRONMENT=development          # development | production
DEBUG=true                       # Set to false in production
APP_NAME=Velora
APP_VERSION=0.1.0
SECRET_KEY=change-me-to-a-64-char-random-string-never-commit-this

# ---------------------------------------------------------------------------
# Database (PostgreSQL via Neon)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/velora
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false              # Set to true to log all SQL queries

# ---------------------------------------------------------------------------
# Redis (Upstash)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-64-char-random-jwt-secret-never-commit
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ---------------------------------------------------------------------------
# LLM Provider API Keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_ENABLED=true

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://velora.vercel.app
CORS_ALLOW_CREDENTIALS=true

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                  # json | console (use console for local dev)

# ---------------------------------------------------------------------------
# Background tasks
# ---------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL_SECONDS=60
PROVIDER_HEALTH_CHECK_TIMEOUT=5

# ---------------------------------------------------------------------------
# Telemetry (OpenTelemetry — optional in dev)
# ---------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=velora-backend
